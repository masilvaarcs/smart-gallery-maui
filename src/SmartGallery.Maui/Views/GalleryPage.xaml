<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartGallery.Maui.ViewModels"
             xmlns:conv="clr-namespace:SmartGallery.Maui.Converters"
             x:Class="SmartGallery.Maui.Views.GalleryPage"
             x:DataType="vm:GalleryViewModel"
             Title="Galeria"
             Shell.NavBarIsVisible="True">

    <ContentPage.Resources>
        <conv:TagsToStringConverter x:Key="TagsToString" />
        <conv:BytesToStringConverter x:Key="BytesToString" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="12">
        
        <!-- Search Bar -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Placeholder="Buscar por tags ou título..."
                   Text="{Binding SearchText}"
                   ReturnCommand="{Binding BuscarCommand}"
                   ReturnType="Search"
                   ClearButtonVisibility="WhileEditing" />
            <Button Grid.Column="1" 
                    Text="🔍" 
                    Command="{Binding BuscarCommand}"
                    WidthRequest="50"
                    BackgroundColor="{StaticResource Primary}" />
        </Grid>

        <!-- Status -->
        <Label Grid.Row="1" 
               Text="{Binding StatusText}" 
               FontSize="12" 
               TextColor="{AppThemeBinding Light=Gray, Dark=#ACACAC}"
               HorizontalOptions="Start" />

        <!-- Image Grid -->
        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding Imagens}"
                        RemainingItemsThreshold="5"
                        RemainingItemsThresholdReachedCommand="{Binding CarregarMaisCommand}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding AbrirDetalheCommand}"
                        SelectionChangedCommandParameter="{Binding Source={RelativeSource Self}, Path=SelectedItem}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
            </CollectionView.ItemsLayout>
            
            <CollectionView.EmptyView>
                <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Padding="40">
                    <Label Text="📷" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Nenhuma imagem encontrada" FontSize="16" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=Gray, Dark=#ACACAC}" />
                    <Label Text="Faça upload de imagens pela aba Upload" FontSize="12" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=LightGray, Dark=#6E6E6E}" />
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:Object">
                    <Frame Padding="0" CornerRadius="12" HasShadow="True" IsClippedToBounds="True"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#242424}">
                        <Grid RowDefinitions="150,Auto,Auto" Padding="0">
                            <Image Source="{Binding UrlThumbnail}"
                                   Aspect="AspectFill"
                                   HeightRequest="150" />
                            <Label Grid.Row="1" 
                                   Text="{Binding Titulo}" 
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   LineBreakMode="TailTruncation"
                                   Margin="8,6,8,0" />
                            <Label Grid.Row="2"
                                   Text="{Binding Tags, Converter={StaticResource TagsToString}}"
                                   FontSize="10"
                                   TextColor="{StaticResource Primary}"
                                   LineBreakMode="TailTruncation"
                                   Margin="8,0,8,8" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="3" 
                           IsRunning="{Binding IsLoading}" 
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource Primary}" />
    </Grid>

</ContentPage>
