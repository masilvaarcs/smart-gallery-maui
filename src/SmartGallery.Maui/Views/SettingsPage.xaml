<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartGallery.Maui.ViewModels"
             x:Class="SmartGallery.Maui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Configurações">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Label Text="⚙️ Configurações" FontSize="24" FontAttributes="Bold" />
            <Label Text="Configure a URL da API do Smart Gallery AWS." FontSize="13" TextColor="Gray" />

            <!-- API URL -->
            <Frame Padding="16" CornerRadius="12" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="URL da API" FontAttributes="Bold" />
                    <Entry Text="{Binding ApiUrl}" 
                           Placeholder="https://xxxxx.execute-api.us-east-1.amazonaws.com/prod"
                           Keyboard="Url" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="🔗 Testar"
                                Command="{Binding TestarConexaoCommand}"
                                BackgroundColor="#2196F3" />
                        <Button Grid.Column="1" 
                                Text="💾 Salvar"
                                Command="{Binding SalvarCommand}"
                                BackgroundColor="{StaticResource Primary}" />
                    </Grid>

                    <ActivityIndicator IsRunning="{Binding IsTesting}" IsVisible="{Binding IsTesting}" />

                    <Label Text="{Binding StatusText}" FontSize="13" TextColor="Gray" />
                </VerticalStackLayout>
            </Frame>

            <!-- About -->
            <Frame Padding="16" CornerRadius="12" BackgroundColor="#F5F5F5">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Sobre o Smart Gallery Viewer" FontAttributes="Bold" FontSize="16" />
                    <Label Text="Client .NET MAUI para o Smart Gallery AWS — galeria de imagens serverless com auto-tagging via Amazon Rekognition."
                           FontSize="13" TextColor="Gray" />
                    <Label Text="Versão 1.0.0" FontSize="11" TextColor="LightGray" />
                    <Label FontSize="11" TextColor="{StaticResource Primary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Backend: " />
                                <Span Text="github.com/MarcosSilva-Dev/smart-gallery-aws" TextDecorations="Underline" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
