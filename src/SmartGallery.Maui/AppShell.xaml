<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartGallery.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SmartGallery.Maui.Views"
    Title="Smart Gallery"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent Title="Galeria" Icon="gallery_icon" Route="galeria"
                      ContentTemplate="{DataTemplate views:GalleryPage}" />
        <ShellContent Title="Upload" Icon="upload_icon" Route="upload"
                      ContentTemplate="{DataTemplate views:UploadPage}" />
        <ShellContent Title="Dashboard" Icon="dashboard_icon" Route="dashboard"
                      ContentTemplate="{DataTemplate views:DashboardPage}" />
        <ShellContent Title="Config" Icon="settings_icon" Route="settings"
                      ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>

</Shell>
