<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:SmartGallery.Maui.Converters"
             x:Class="SmartGallery.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:InverseBoolConverter x:Key="InverseBool" />
            <conv:BytesToStringConverter x:Key="BytesToString" />
            <conv:TagsToStringConverter x:Key="TagsToString" />
            <conv:PercentToWidthConverter x:Key="PercentToWidth" />
            <conv:IsNotNullConverter x:Key="IsNotNullConverter" />
            <conv:IsNullConverter x:Key="IsNullConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
